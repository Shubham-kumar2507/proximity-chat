# Simple production serve — web is built locally before Docker build
FROM nginx:1.27-alpine
COPY mobile/dist /usr/share/nginx/html
COPY mobile/nginx.web.conf /etc/nginx/conf.d/default.conf

# Fix Metro bundler issue: Convert the script tag to a module so `import.meta` from Reanimated v4 is parsed correctly
RUN sed -i 's/<script src=/<script type="module" src=/g' /usr/share/nginx/html/index.html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
